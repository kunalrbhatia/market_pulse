{
  "name": "market-pulse",
  "version": "1.0.0",
  "description": "Universal self-healing engine for algorithmic trading repos",
  "main": "dist/engine.js",
  "scripts": {
    "dev": "ts-node engine.ts",
    "build": "tsc",
    "start": "node dist/engine.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint **/*.ts --max-warnings=0",
    "lint:fix": "eslint **/*.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-readme": "node .agents/skills/readme-auto-update/scripts/check-readme.cjs",
    "check-pr-description": "node .agents/skills/pr-description-check/scripts/verify.cjs",
    "bootstrap": "ts-node scripts/bootstrap.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.64.0"
  }
}
